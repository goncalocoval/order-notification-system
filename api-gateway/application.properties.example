server.port=8080

spring.cloud.gateway.server.webmvc.routes[0].id=order-service
spring.cloud.gateway.server.webmvc.routes[0].uri=http://order-service:8081
spring.cloud.gateway.server.webmvc.routes[0].predicates[0]=Path=/orders/**

spring.cloud.gateway.server.webmvc.routes[1].id=notifications-service
spring.cloud.gateway.server.webmvc.routes[1].uri=http://notification-service:8082
spring.cloud.gateway.server.webmvc.routes[1].predicates[0]=Path=/notifications/**